# Database Configuration - Neon PostgreSQL
# Get your connection string from: https://console.neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# Example: postgresql://user:pass@ep-cool-name-12345.us-east-2.aws.neon.tech/audit_management?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx-xxxx.us-east-2.aws.neon.tech/audit_management?sslmode=require"

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# Logging
LOG_LEVEL=debug
