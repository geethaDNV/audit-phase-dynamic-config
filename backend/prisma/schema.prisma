// Prisma Schema for Metadata-Driven Audit Management System
// Database: PostgreSQL (Neon)
// Models: 15 tables supporting 6 representative steps across 2 phases

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE AUDIT MODELS
// ============================================================================

model Audit {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(200)
  description String?   @db.Text
  status      String    @default("draft") @db.VarChar(50) // draft, in-progress, completed, archived
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  client          Client?
  phases          AuditPhase[]
  checklistItems  ChecklistItem[]
  documents       Document[]
  findings        Finding[]
  riskAssessment  RiskAssessment?
  stepData        StepData[]
  stepStatuses    AuditStepStatus[]

  @@index([status])
  @@index([createdAt])
}

model AuditPhase {
  id          Int       @id @default(autoincrement())
  auditId     Int
  phaseId     Int       // 1 = Client Assessment, 2 = Checklist Execution
  phaseName   String    @db.VarChar(100)
  status      String    @default("pending") @db.VarChar(50) // pending, in-progress, completed
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, phaseId])
  @@index([auditId])
  @@index([status])
}

// ============================================================================
// STEP 1: CLIENT BASIC INFORMATION (Pattern 1: Simple CRUD)
// ============================================================================

model Client {
  id             Int       @id @default(autoincrement())
  auditId        Int       @unique
  name           String    @db.VarChar(100)
  email          String    @db.VarChar(100)
  industry       String    @db.VarChar(50)
  phone          String?   @db.VarChar(20)
  address        String?   @db.VarChar(255)
  website        String?   @db.VarChar(255)
  taxId          String?   @db.VarChar(50)
  fiscalYearEnd  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  audit             Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)
  entities          Entity[]
  contacts          Contact[]
  selectedEntityId  Int?      // For Step 2

  @@index([auditId])
  @@index([email])
}

// ============================================================================
// STEP 2: ENTITY SELECTION & CONTACTS (Pattern 2: Multi-source Compose)
// ============================================================================

model Entity {
  id                 Int     @id @default(autoincrement())
  clientId           Int
  name               String  @db.VarChar(200)
  type               String  @db.VarChar(50) // corporation, llc, partnership, sole-proprietorship
  description        String? @db.Text
  registrationNumber String? @db.VarChar(50)
  isActive           Boolean @default(true)

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([type])
}

model Contact {
  id        Int     @id @default(autoincrement())
  clientId  Int
  name      String  @db.VarChar(100)
  email     String  @db.VarChar(100)
  phone     String? @db.VarChar(20)
  role      String? @db.VarChar(100)
  isPrimary Boolean @default(false)

  // Relations
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([email])
}

// ============================================================================
// STEP 3: RISK ASSESSMENT (Pattern 3: Complex Fetch + Simple Save)
// ============================================================================

model RiskAssessment {
  id             Int      @id @default(autoincrement())
  auditId        Int      @unique
  riskLevel      String   @db.VarChar(20) // Low, Medium, High, Critical
  riskScore      Float    // 0-100
  previousRisk   String?  @db.VarChar(20)
  justification  String?  @db.Text
  assessedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([riskLevel])
  @@index([assessedAt])
}

// ============================================================================
// STEP 4: CHECKLIST EXECUTION (Pattern 4: Array CRUD)
// ============================================================================

model ChecklistItem {
  id          Int       @id @default(autoincrement())
  auditId     Int
  title       String    @db.VarChar(200)
  description String?   @db.Text
  category    String    @db.VarChar(50) // Financial, Operational, Compliance, IT, HR, Other
  priority    String    @db.VarChar(20) // Low, Medium, High, Critical
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId])
  @@index([category])
  @@index([priority])
  @@index([isCompleted])
}

// ============================================================================
// STEP 5: DOCUMENT REVIEW (Pattern 5: Conditional Save)
// ============================================================================

model Document {
  id             Int      @id @default(autoincrement())
  auditId        Int
  title          String   @db.VarChar(255)
  fileName       String?  @db.VarChar(255)
  documentType   String   @db.VarChar(50) // Financial Statement, PDF, Excel, Word, Image
  fileType       String?  @db.VarChar(50) // PDF, Excel, Word, Image
  fileSize       Int?     // in bytes
  filePath       String?  @db.VarChar(500)
  description    String?  @db.Text
  isConfidential Boolean  @default(false)
  tags           String[] @default([])
  uploadedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  audit          Audit           @relation(fields: [auditId], references: [id], onDelete: Cascade)
  review         DocumentReview?
  evidenceLinks  Evidence[]

  @@index([auditId])
  @@index([auditId, documentType])
  @@index([uploadedAt])
  @@index([isConfidential])
  @@index([fileType])
  @@index([documentType])
}

model DocumentReview {
  id            Int       @id @default(autoincrement())
  documentId    Int       @unique
  status        String    @db.VarChar(50) // pending, approved, rejected
  reviewedBy    String?   @db.VarChar(100)
  reviewedAt    DateTime?
  justification String?   @db.Text // Required when status = rejected
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([status])
}

// ============================================================================
// STEP 6: FINDINGS & RECOMMENDATIONS (Pattern 6: Complex Transaction)
// ============================================================================

model Finding {
  id          Int      @id @default(autoincrement())
  auditId     Int
  title       String   @db.VarChar(200)
  description String   @db.Text
  severity    String   @db.VarChar(20) // Low, Medium, High, Critical
  category    String   @db.VarChar(100) // Type of finding
  status      String   @default("open") @db.VarChar(50) // open, in-review, resolved, closed
  assignedTo  String?  @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  audit           Audit               @relation(fields: [auditId], references: [id], onDelete: Cascade)
  evidence        Evidence[]
  recommendations Recommendation[]
  auditTrail      FindingAuditTrail[]

  @@index([auditId])
  @@index([auditId, severity])
  @@index([auditId, status])
  @@index([createdAt])
  @@index([severity])
  @@index([status])
  @@index([category])
}

model Evidence {
  id           Int      @id @default(autoincrement())
  findingId    Int
  documentId   Int?     // References Step 5 documents
  description  String   @db.VarChar(500)
  source       String?  @db.VarChar(200)
  documentPath String?  @db.VarChar(500)
  type         String?  @db.VarChar(50) // Document, Screenshot, Interview, System Log
  metadata     Json?    // Additional structured data
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  finding  Finding   @relation(fields: [findingId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id])

  @@index([findingId])
  @@index([documentId])
  @@index([type])
}

model Recommendation {
  id          Int       @id @default(autoincrement())
  findingId   Int
  description String    @db.Text
  priority    String    @db.VarChar(20) // Low, Medium, High
  status      String    @default("pending") @db.VarChar(50) // pending, accepted, rejected, implemented
  targetDate  DateTime?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
  @@index([priority])
  @@index([status])
}

model FindingAuditTrail {
  id        Int      @id @default(autoincrement())
  findingId Int
  action    String   @db.VarChar(100) // created, updated, status_changed, evidence_added, etc.
  changedBy String   @db.VarChar(100)
  changedAt DateTime @default(now())
  changes   Json     // Snapshot of what changed

  // Relations
  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
  @@index([changedAt])
}

// ============================================================================
// METADATA STORAGE
// ============================================================================

// NEW: Phase configuration - fully dynamic phases
model PhaseConfiguration {
  id           Int      @id @default(autoincrement())
  phaseId      Int      @unique
  phaseName    String   @db.VarChar(100)
  phaseKey     String   @unique // "client-assessment", "audit-execution"
  description  String?  @db.Text
  displayOrder Int      // For ordering phases in UI
  icon         String?  // Icon name or emoji for UI
  color        String?  // Color code for UI theming
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([displayOrder])
  @@index([isActive])
}

model StepConfiguration {
  id            Int      @id @default(autoincrement())
  stepKey       String   @unique // "1-1", "2-5"
  phaseId       Int
  stepId        Int
  stepName      String   @db.VarChar(100)
  description   String?  @db.Text
  formSchema    Json     // Serialized FormSchema
  dataConfig    Json     // Serialized DataConfig
  businessRules Json?    // Business rules
  dependencies  Json?    // NEW: Dependency configuration
  isActive      Boolean  @default(true)
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([phaseId, stepId])
  @@index([phaseId])
  @@index([stepKey])
  @@index([isActive])
  @@index([version])
}

// NEW: Track step completion and dependencies at runtime
model AuditStepStatus {
  id            Int       @id @default(autoincrement())
  auditId       Int
  phaseId       Int
  stepId        Int
  stepKey       String    // "1-1"
  status        String    @default("pending") // pending, in-progress, completed, skipped, blocked
  startedAt     DateTime?
  completedAt   DateTime?
  blockedBy     String[]  @default([]) // Array of stepKeys: ["1-1", "1-2"]
  blockedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, phaseId, stepId])
  @@index([auditId])
  @@index([auditId, status])
  @@index([stepKey])
  @@index([auditId, phaseId])
}

// StepData: Metadata and audit trail ONLY (not a duplicate of domain data)
// 
// ARCHITECTURE CHANGE: Domain tables (Client, Document, etc.) are the single source of truth.
// StepData now stores ONLY:
// - Metadata: submission timestamps, user info, validation status
// - Audit trail: what was submitted vs. what was saved
// - Draft state: incomplete/unsaved form data
// - UI state: for steps without domain models
// 
// DO NOT use for cross-step validation - query domain tables directly instead
model StepData {
  id        Int      @id @default(autoincrement())
  auditId   Int
  phaseId   Int
  stepId    Int
  stepKey   String   // Denormalized for faster lookups
  data      Json?    // Optional: metadata, not actual form data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@unique([auditId, phaseId, stepId])
  @@index([auditId])
  @@index([auditId, phaseId])
  @@index([stepKey])
  @@index([updatedAt])
  @@index([auditId, stepKey])
}
